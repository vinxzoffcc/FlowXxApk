<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:padding="16dp" android:paddingBottom="8dp">
        <LinearLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_accent_circle" android:gravity="center">
            <TextView android:text="AI" android:textSize="12sp" android:textStyle="bold" android:textColor="#fff"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
            <TextView android:text="FlowX AI" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
            <TextView android:text="Asisten gaming kamu" android:textSize="11sp" android:textColor="@color/text_hint"/>
        </LinearLayout>
        <TextView android:text="● Online" android:textSize="11sp" android:textColor="@color/green"/>
    </LinearLayout>

    <!-- Chat area -->
    <ScrollView android:id="@+id/scroll_chat"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="12dp">
        <TextView android:id="@+id/tv_chat"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="@color/text_primary"
            android:lineSpacingExtra="4dp" android:fontFamily="sans-serif"/>
    </ScrollView>

    <!-- Input -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical"
        android:background="@color/surface" android:elevation="4dp">
        <EditText android:id="@+id/et_chat_input"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Ketik pesan..."
            android:background="@drawable/bg_input" android:padding="10dp"
            android:textSize="13sp" android:maxLines="3"
            android:inputType="textMultiLine" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_send"
            android:layout_width="44dp" android:layout_height="44dp"
            android:text="➤" android:textSize="14sp"
            android:backgroundTint="@color/accent" android:padding="0dp"/>
    </LinearLayout>
</LinearLayout>
